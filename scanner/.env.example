# SecureSG Skill Safety Scanner — example environment configuration.
#
# Copy to `.env` for tooling that reads dotenv (e.g. scripts/build-gallery.ts).
# Local Worker dev reads `.dev.vars` instead (see .dev.vars.example); production
# secrets are set with `wrangler secret put <NAME>` and never committed.
#
# Required sponsor credentials (no defaults — fail-closed if absent).
EXA_API_KEY=
OPENAI_API_KEY=

# Optional credential. A GitHub token lifts the GitHub API rate limit from 60/hr
# (unauthenticated, shared per Cloudflare egress IP) to 5000/hr when resolving a
# SKILL.md from a github.com repo or tree URL. Public repos need a token with NO
# scopes. Without it, repo/tree URLs may fail with a rate-limit error; raw
# SKILL.md and blob URLs never hit the API and are unaffected.
# GITHUB_TOKEN=

# Optional SCANNER_* tunables. All have documented defaults in worker/config.ts;
# uncomment only to override. Values are read from env, never hardcoded inline.
#
# SCANNER_MAX_URLS=8                 # max URLs scanned per skill (subrequest budget)
# SCANNER_MAX_REDIRECT_HOPS=5        # max redirect hops traced per URL
# SCANNER_SUBREQUEST_CAP=50          # Cloudflare free-plan subrequest ceiling
# SCANNER_REDIRECT_TIMEOUT_MS=5000   # per-hop redirect fetch timeout
# SCANNER_EXA_TIMEOUT_MS=10000       # Exa getContents request timeout
# SCANNER_JUDGE_TIMEOUT_MS=15000     # OpenAI judge request timeout
# SCANNER_REVIEW_THRESHOLD=0.4       # p_injection >= -> HUMAN_APPROVAL_REQUIRED
# SCANNER_BLOCK_THRESHOLD=0.7        # p_injection >= -> BLOCK
# SCANNER_OPENAI_MODEL=gpt-5.5       # judge model id (fallback gpt-4o-mini)
# SCANNER_EXA_MAX_CHARACTERS=2000    # max chars of Exa content per URL
# SCANNER_GENESIS_SEED=securesg-scanner-genesis  # proof-chain genesis seed
# SCANNER_ALLOWED_SCHEMES=https      # comma-separated allowed URL schemes
# SCANNER_URL_SHORTENERS=bit.ly,tinyurl.com,t.co,goo.gl,ow.ly  # known shortener hosts
