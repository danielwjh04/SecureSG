# SecureSG configuration. Copy to a local .env file (never commit .env).
# All keys use the SECURESG_ prefix and are loaded by secureSG/config/settings.py.

# Path to the append-only SQLite audit database.
SECURESG_DB_PATH=./securesg_audit.db

# Seed string used to derive the genesis hash of the audit chain.
# Changing this starts a new, independent chain.
SECURESG_GENESIS_SEED=securesg-genesis-v1

# SQLite journal mode. WAL is required for concurrent append + verify.
SECURESG_SQLITE_JOURNAL_MODE=WAL

# OpenAI semantic layer. The guard judge and (by default) Warden embeddings run
# on OpenAI. The API key is read from the standard, unprefixed OPENAI_API_KEY
# (matching the scanner). Leave it unset to run deterministic-only (the Enforcer
# is constructed without a Screener; intent drift is disabled).
# OPENAI_API_KEY=sk-...
# SECURESG_OPENAI_BASE_URL=https://api.openai.com/v1   # override for Azure / a gateway
# SECURESG_OPENAI_GUARD_MODEL=gpt-5.5
# SECURESG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# SECURESG_OPENAI_REQUEST_TIMEOUT=60.0
# SECURESG_OPENAI_ASSESS_MAX_TOKENS=256
# SECURESG_OPENAI_AUTHOR_MAX_TOKENS=1024

# Semantic verdict thresholds. Must satisfy 0 < review < block <= 1.
# SECURESG_SEMANTIC_REVIEW_THRESHOLD=0.50
# SECURESG_SEMANTIC_BLOCK_THRESHOLD=0.80

# (SP4) Warden embedding backend: "openai" (the default, no torch) or
# "sentence-transformers" (in-process MiniLM, needs the requirements-ml.txt
# wheels). Recalibrate the drift thresholds if you switch the embedding model.
# SECURESG_EMBEDDING_PROVIDER=sentence-transformers
