# SecureSG configuration. Copy to a local .env file (never commit .env).
# All keys use the SECURESG_ prefix and are loaded by secureSG/config/settings.py.

# Path to the append-only SQLite audit database.
SECURESG_DB_PATH=./securesg_audit.db

# Seed string used to derive the genesis hash of the audit chain.
# Changing this starts a new, independent chain.
SECURESG_GENESIS_SEED=securesg-genesis-v1

# SQLite journal mode. WAL is required for concurrent append + verify.
SECURESG_SQLITE_JOURNAL_MODE=WAL

# (SP3) GuardFormer local model. Download weights with:
#   python -m scripts.fetch_model
# Then point MODEL_PATH at the GGUF. Leave unset to run deterministic-only
# (the Enforcer is constructed without a Screener).
# SECURESG_MODEL_PATH=./model_weights/Qwen_Qwen3-0.6B-Q4_K_M.gguf
# SECURESG_MODEL_REPO_ID=bartowski/Qwen_Qwen3-0.6B-GGUF
# SECURESG_MODEL_FILENAME=Qwen_Qwen3-0.6B-Q4_K_M.gguf
# SECURESG_MODEL_DIR=./model_weights

# (SP3) Semantic verdict thresholds. Must satisfy 0 < review < block <= 1.
# SECURESG_SEMANTIC_REVIEW_THRESHOLD=0.50
# SECURESG_SEMANTIC_BLOCK_THRESHOLD=0.80
